# ============================================================
# KGB_Bot — пример конфигурации.
# Скопируйте этот файл в .env и впишите свои значения:
#     cp .env.example .env
# Файл .env в git НЕ попадает (см. .gitignore). На сервере — права 0600.
# ============================================================

# --- Telegram (обязательно) ---
# Токен бота от @BotFather. Выключите боту privacy mode (или сделайте его
# админом чата) и переподключите к чатам — иначе он не видит обычные сообщения.
TELEGRAM_BOT_TOKEN=

# --- LLM (обязательно) ---
# Ключ OpenAI API. Содержимое чатов отправляется в этот сервис.
OPENAI_API_KEY=

# Переключение на OpenRouter (или другой OpenAI-совместимый шлюз):
# поменяйте base_url и положите сюда соответствующий ключ.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Модели по ролям (необязательно, значения по умолчанию ниже):
# LLM_TRIAGE_MODEL=gpt-4.1-nano
# LLM_EXTRACT_MODEL=gpt-4.1-mini
# LLM_ANSWER_MODEL=gpt-4.1-mini
# LLM_EMBED_MODEL=text-embedding-3-small

# --- Репозиторий базы знаний (для выгрузки выжимок) ---
# ОТДЕЛЬНЫЙ ПРИВАТНЫЙ репозиторий, куда бот коммитит Markdown со знаниями.
# Без этих настроек знания пишутся только локально (data/kb), без пуша.
# KB_REPO_URL=git@github.com:<owner>/<your-knowledge-repo>.git
# Вариант A — deploy key (рекомендуется; scoped только на этот репо):
#   ssh-keygen -t ed25519 -f ~/.ssh/kgb_kb_deploy -N ""
#   публичную часть добавьте в репо: Settings → Deploy keys → Allow write access
# KB_REPO_DEPLOY_KEY_PATH=/home/<user>/.ssh/kgb_kb_deploy
# Вариант B — fine-grained PAT, scoped ТОЛЬКО на этот репо (Contents: read+write):
# KB_REPO_TOKEN=

# --- Доступ / админ ---
# Telegram user_id первого администратора (бот добавит его в whitelist на старте).
# Свой id можно узнать у @userinfobot.
# ADMIN_USER_ID=
# Время жизни кэша членства в чатах, сек.
# MEMBERSHIP_TTL_SECONDS=3600

# --- Хранилище (необязательно, пути по умолчанию) ---
# DB_PATH=./data/secretary.db
# KB_LOCAL_PATH=./data/kb

# --- Пороги извлечения/ответов (необязательно) ---
# CONFIDENCE_THRESHOLD=0.5
# DUP_SIMILARITY_THRESHOLD=0.90
# RELEVANCE_SIMILARITY_THRESHOLD=0.30

# --- Расписание и бюджеты (необязательно) ---
# EXTRACT_MESSAGE_THRESHOLD=50      # порог новых сообщений для авто-извлечения
# SCAN_INTERVAL_SECONDS=300         # как часто планировщик сканирует чаты
# EXTRACT_BUDGET_PER_CHAT=1000      # макс. сообщений за один прогон на чат
# EXTRACT_BUDGET_GLOBAL=10000       # макс. сообщений за период (анти-слив токенов)
# BUDGET_PERIOD_SECONDS=3600        # длительность бюджетного периода
# QUERY_RATE_LIMIT_PER_MIN=10       # лимит запросов к боту на пользователя
# LEAVE_UNSANCTIONED_CHATS=false    # авто-выход из непривязанных чатов
